{
  "version": 3,
  "agents": {
    "defaults": {
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model": {
        "primary": "groq",
        "fallbacks": [
          "groq-fallback",
          "groq-large"
        ]
      },
      "max_tokens": 1024,
      "context_window": 8192,
      "temperature": 0.7,
      "max_tool_iterations": 3,
      "summarize_message_threshold": 10,
      "summarize_token_percent": 75,
      "split_on_marker": false,
      "max_llm_retries": 1,
      "llm_retry_backoff_secs": 20,
      "tool_feedback": {
        "enabled": false,
        "max_args_length": 300,
        "separate_messages": false
      }
    }
  },
  "model_list": [
    {
      "model_name": "groq",
      "model": "groq/llama-3.1-8b-instant",
      "api_keys": [
        "$GROQ_API_KEY"
      ],
      "api_base": "https://api.groq.com/openai/v1"
    },
    {
      "model_name": "groq-fallback",
      "model": "groq/llama-3.2-3b-preview",
      "api_keys": [
        "$GROQ_API_KEY"
      ],
      "api_base": "https://api.groq.com/openai/v1"
    },
    {
      "model_name": "groq-large",
      "model": "groq/llama-3.3-70b-versatile",
      "api_keys": [
        "$GROQ_API_KEY"
      ],
      "api_base": "https://api.groq.com/openai/v1"
    }
  ],
  "channel_list": {
    "telegram": {
      "enabled": true,
      "type": "telegram",
      "allow_from": [
        "$TELEGRAM_USER_ID"
      ],
      "reasoning_channel_id": "",
      "settings": {
        "token": "$TELEGRAM_BOT_TOKEN",
        "base_url": "",
        "proxy": "",
        "use_markdown_v2": false,
        "streaming": {
          "enabled": false
        }
      }
    }
  },
  "tools": {
    "web": {
      "enabled": true,
      "prefer_native": true,
      "format": "plaintext",
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      }
    },
    "cron": {
      "enabled": false,
      "exec_timeout_minutes": 5
    },
    "exec": {
      "enabled": false,
      "enable_deny_patterns": true
    },
    "read_file": {
      "enabled": true
    },
    "write_file": {
      "enabled": true
    },
    "list_dir": {
      "enabled": true
    },
    "web_fetch": {
      "enabled": true
    },
    "subagent": {
      "enabled": false
    },
    "message": {
      "enabled": true
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 10000,
    "hot_reload": false,
    "log_level": "info"
  }
}
